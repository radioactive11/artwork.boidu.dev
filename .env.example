MEDIA_USER_TOKEN=

# Postgres connection string. On Railway, set this to ${{Postgres.DATABASE_URL}}
# so it auto-injects from the linked Postgres service.
# If unset, the API still works but every request hits Apple Music (no cache).
DATABASE_URL=

# Inbound rate limiting (per IP, with progressive escalation for repeat offenders).
# All optional — defaults shown below.
RATE_LIMIT_BASE=60
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PENALTY_BASE_MS=60000
RATE_LIMIT_PENALTY_MAX=5

# Outbound throttle for amp-api.music.apple.com calls.
# Conservative defaults — Apple's undocumented quota appears very tight.
# Drop APPLE_RATE further (e.g. 0.25) if you still see 429s in prod.
APPLE_RATE=0.5
APPLE_BURST=3
APPLE_RETRY_ATTEMPTS=3
APPLE_RETRY_BASE_MS=500

# Circuit breaker: if Apple keeps returning 429 after retries,
# trip the circuit and short-circuit to 503 for a cooldown period.
# Cooldown escalates: base × multiplier^(trips-1), capped at max.
# Default ladder (5m base × 4): 5m → 20m → 80m → 240m (cap).
# Resets fully on any successful upstream call.
APPLE_CIRCUIT_THRESHOLD=3
APPLE_CIRCUIT_BASE_OPEN_MS=300000
APPLE_CIRCUIT_MAX_OPEN_MS=14400000
APPLE_CIRCUIT_MULTIPLIER=4

# Log verbosity: debug | info | warn | error (default: info)
# debug is useful for tracing cache hits/misses and upstream timings during development.
LOG_LEVEL=info
